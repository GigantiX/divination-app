# ===========================================
# DIVINATION DASHBOARD - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local and fill in your own values
# DO NOT commit .env.local to version control

# ------------------
# SUPABASE (New API Keys)
# ------------------
# Get these from: https://supabase.com/dashboard/project/[your-project]/settings/api
# Use the new "API Keys" tab, not "Legacy API Keys"
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

# ------------------
# DATABASE (Prisma)
# ------------------
# Get these from: Dashboard → Connect button → ORMs tab → Prisma
# Transaction mode (for app queries via connection pooler)
DATABASE_URL="postgres://postgres.[project-ref]:[password]@xxx.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session mode (for Prisma migrations)
DIRECT_URL="postgres://postgres.[project-ref]:[password]@xxx.pooler.supabase.com:5432/postgres"

# ------------------
# NEXTAUTH
# ------------------
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_generated_nextauth_secret

# ------------------
# APP CONFIGURATION
# ------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ------------------
# FACEBOOK CONNECT (Profile -> Connect Facebook)
# ------------------
# Create app at https://developers.facebook.com and enable Facebook Login (Web)
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
# Base URL used by server redirects and OAuth callback construction
APP_BASE_URL=http://localhost:3000
# Optional override if your callback path differs
# FACEBOOK_REDIRECT_URI=http://localhost:3000/api/facebook/callback

# ------------------
# OPTIONAL
# ------------------
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
