# ===========================================
# DIVINATION DASHBOARD - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local and fill in your own values
# DO NOT commit .env.local to version control

# ------------------
# DATABASE (Supabase)
# ------------------
# Get these from: https://supabase.com/dashboard/project/[your-project]/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ------------------
# DATABASE (Alternative: Direct PostgreSQL)
# ------------------
# Use this if you prefer direct PostgreSQL connection (e.g., with Prisma)
# DATABASE_URL=postgresql://user:password@host:5432/database_name

# ------------------
# AUTHENTICATION
# ------------------
# NextAuth.js Configuration
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_key

# JWT Configuration
JWT_SECRET=your_jwt_secret_for_token_signing

# ------------------
# FILE STORAGE (Optional)
# ------------------
# For storing report images, profile photos, etc.
# Option 1: Supabase Storage (uses same Supabase keys above)
# Option 2: Cloudinary
# CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
# CLOUDINARY_API_KEY=your_cloudinary_api_key
# CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ------------------
# EMAIL SERVICE (Optional)
# ------------------
# For password reset, notifications, etc.
# Option: Resend (recommended for Next.js)
# RESEND_API_KEY=your_resend_api_key
# EMAIL_FROM=noreply@yourdomain.com

# ------------------
# APP CONFIGURATION
# ------------------
# Application URL (change for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App environment
NODE_ENV=development

# ------------------
# ANALYTICS (Optional)
# ------------------
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
